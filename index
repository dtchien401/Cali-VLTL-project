<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dự án Vật lý trị liệu - Business Model</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap');
        body { font-family: 'Inter', sans-serif; }
        .gradient-bg { background: linear-gradient(135deg, #0f172a 0%, #1e3a8a 100%); }
        .tab-active { border-bottom: 4px solid #3b82f6; color: #1e40af; font-weight: 700; }
        .hidden { display: none; }
    </style>
</head>
<body class="bg-slate-50 text-slate-800">

    <!-- Header -->
    <header class="gradient-bg text-white py-12 px-6 shadow-xl">
        <div class="max-w-6xl mx-auto flex flex-col md:flex-row justify-between items-center">
            <div class="text-center md:text-left">
                <h1 class="text-3xl md:text-4xl font-bold mb-2 tracking-tight">Cali Physical Therapy Center</h1>
                <p class="text-blue-200 text-lg">Hệ thống phục hồi chức năng & Trị liệu công nghệ cao</p>
            </div>
            <div class="mt-6 md:mt-0 flex gap-4">
                <div class="bg-white/10 p-3 rounded-lg text-center min-w-[120px]">
                    <span class="block text-xs uppercase opacity-70">Tổng vốn đầu tư</span>
                    <span class="text-xl font-bold">879M VND</span>
                </div>
                <div class="bg-green-500/20 p-3 rounded-lg text-center min-w-[120px] border border-green-500/30">
                    <span class="block text-xs uppercase opacity-70 font-bold text-green-300">Hoàn vốn (ROI)</span>
                    <span class="text-xl font-bold text-green-400">9 Tháng</span>
                </div>
            </div>
        </div>
    </header>

    <!-- Navigation Tabs -->
    <nav class="bg-white border-b sticky top-0 z-50 shadow-sm">
        <div class="max-w-6xl mx-auto flex">
            <button onclick="switchTab('services')" id="btn-services" class="tab-active py-4 px-8 text-sm uppercase tracking-wider flex items-center gap-2">
                <i class="fas fa-concierge-bell"></i> Dịch vụ & Quy trình
            </button>
            <button onclick="switchTab('business')" id="btn-business" class="py-4 px-8 text-sm uppercase tracking-wider text-slate-500 flex items-center gap-2">
                <i class="fas fa-chart-line"></i> Mô hình kinh doanh (Capex)
            </button>
        </div>
    </nav>

    <!-- Tab 1: Services Content -->
    <main id="tab-services" class="max-w-6xl mx-auto py-10 px-6">
        <!-- Overview Grid -->
        <div class="grid md:grid-cols-3 gap-6 mb-12">
            <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100">
                <div class="w-12 h-12 bg-blue-100 text-blue-600 rounded-xl flex items-center justify-center text-xl mb-4">
                    <i class="fas fa-microchip"></i>
                </div>
                <h3 class="font-bold text-slate-900 mb-2">Công nghệ lõi</h3>
                <p class="text-sm text-slate-500 leading-relaxed">CURAPULS 970, ENDOMED 482 và SONOPULS 490 được tích hợp trong mọi liệu trình.</p>
            </div>
            <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100">
                <div class="w-12 h-12 bg-green-100 text-green-600 rounded-xl flex items-center justify-center text-xl mb-4">
                    <i class="fas fa-map-marker-alt"></i>
                </div>
                <h3 class="font-bold text-slate-900 mb-2">Địa điểm vận hành</h3>
                <p class="text-sm text-slate-500 leading-relaxed">Triển khai tại 3 trung tâm chiến lược: TTC, TDU và VVO (Đang kiểm tra).</p>
            </div>
            <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100">
                <div class="w-12 h-12 bg-orange-100 text-orange-600 rounded-xl flex items-center justify-center text-xl mb-4">
                    <i class="fas fa-user-check"></i>
                </div>
                <h3 class="font-bold text-slate-900 mb-2">Quy trình chuẩn</h3>
                <p class="text-sm text-slate-500 leading-relaxed">Ký hợp đồng PT → Xác nhận vân tay → Trị liệu viên → Hoàn tất.</p>
            </div>
        </div>

        <!-- Services Table -->
        <div class="bg-white rounded-2xl shadow-sm border overflow-hidden">
            <div class="p-6 border-b bg-slate-50">
                <h2 class="text-xl font-bold">Danh mục gói dịch vụ đề nghị</h2>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead class="bg-slate-50 text-slate-400 text-xs uppercase font-bold">
                        <tr>
                            <th class="px-6 py-4 text-left">Gói dịch vụ</th>
                            <th class="px-6 py-4 text-left">Thời lượng</th>
                            <th class="px-6 py-4 text-left">Quy trình thực hiện</th>
                            <th class="px-6 py-4 text-right">Giá niêm yết</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y text-sm">
                        <tr>
                            <td class="px-6 py-6">
                                <div class="font-bold text-blue-900">Quick Recovery</div>
                                <div class="text-xs text-slate-500">Hội viên Gym, Đau cơ (DOMS)</div>
                            </td>
                            <td class="px-6 py-6 font-medium">30 phút</td>
                            <td class="px-6 py-6 text-slate-600 italic font-light">ENDOMED 482 - Electrotherapy</td>
                            <td class="px-6 py-6 text-right font-bold text-slate-900">690,000 VND</td>
                        </tr>
                        <tr>
                            <td class="px-6 py-6">
                                <div class="font-bold text-blue-900">Office Pain Relief</div>
                                <div class="text-xs text-slate-500">Dân văn phòng, Đau vai gáy/Lưng</div>
                            </td>
                            <td class="px-6 py-6 font-medium">50 phút</td>
                            <td class="px-6 py-6 text-slate-600 italic font-light font-light">Endomed (30p) + Curapuls (20p)</td>
                            <td class="px-6 py-6 text-right font-bold text-slate-900">890,000 VND</td>
                        </tr>
                        <tr>
                            <td class="px-6 py-6">
                                <div class="font-bold text-blue-900">Sports Injury Therapy</div>
                                <div class="text-xs text-slate-500">Chấn thương Tennis/Runner/Gym</div>
                            </td>
                            <td class="px-6 py-6 font-medium">70 phút</td>
                            <td class="px-6 py-6 text-slate-600 italic font-light">Stretch (30p) + Sonopuls (10p) + Endomed (30p)</td>
                            <td class="px-6 py-6 text-right font-bold text-slate-900">1,290,000 VND</td>
                        </tr>
                        <tr>
                            <td class="px-6 py-6">
                                <div class="font-bold text-blue-900">Advance Athlete Recovery</div>
                                <div class="text-xs text-slate-500">Member VIP, Tập cường độ cao</div>
                            </td>
                            <td class="px-6 py-6 font-medium">90 phút</td>
                            <td class="px-6 py-6 text-slate-600 italic font-light">Full combo: Stretch + Sono + Endo + Cura</td>
                            <td class="px-6 py-6 text-right font-bold text-slate-900">1,790,000 VND</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </main>

    <!-- Tab 2: Business Content -->
    <main id="tab-business" class="max-w-6xl mx-auto py-10 px-6 hidden">
        <!-- Capex Summary -->
        <div class="grid md:grid-cols-2 gap-8 mb-12">
            <div class="bg-white p-8 rounded-2xl shadow-sm border">
                <h3 class="text-lg font-bold mb-6 flex items-center gap-2 text-slate-700">
                    <i class="fas fa-wallet text-blue-600"></i> Tổng mức đầu tư (Capex)
                </h3>
                <div class="space-y-4">
                    <div class="flex justify-between items-center pb-4 border-b">
                        <span class="text-slate-500">Máy móc thiết bị (Equipment)</span>
                        <span class="font-bold">659,000,000 VND</span>
                    </div>
                    <div class="flex justify-between items-center pb-4 border-b">
                        <span class="text-slate-500">Cải tạo mặt bằng (Club renovation)</span>
                        <span class="font-bold">220,000,000 VND</span>
                    </div>
                    <div class="flex justify-between items-center pt-2">
                        <span class="font-bold text-slate-900 uppercase">Tổng cộng</span>
                        <span class="text-2xl font-black text-blue-700">879,000,000 VND</span>
                    </div>
                    <div class="text-right text-xs text-slate-400">Tương đương ~ 33,170 USD</div>
                </div>
            </div>

            <div class="bg-blue-900 text-white p-8 rounded-2xl shadow-lg relative overflow-hidden">
                <div class="relative z-10">
                    <h3 class="text-lg font-bold mb-4">Chỉ số tài chính chủ chốt</h3>
                    <div class="grid grid-cols-2 gap-4 mt-6">
                        <div class="bg-white/10 p-4 rounded-xl">
                            <span class="block text-xs opacity-60">EBITDA Năm 1</span>
                            <span class="text-xl font-bold">1.36 tỷ VND</span>
                        </div>
                        <div class="bg-white/10 p-4 rounded-xl">
                            <span class="block text-xs opacity-60">Biên EBITDA</span>
                            <span class="text-xl font-bold">49.0%</span>
                        </div>
                        <div class="bg-white/10 p-4 rounded-xl">
                            <span class="block text-xs opacity-60">Thời gian hoàn vốn</span>
                            <span class="text-xl font-bold text-yellow-400">9.0 Tháng</span>
                        </div>
                        <div class="bg-white/10 p-4 rounded-xl">
                            <span class="block text-xs opacity-60">Free Cashflow Năm 1</span>
                            <span class="text-xl font-bold">355M VND</span>
                        </div>
                    </div>
                </div>
                <div class="absolute -right-10 -bottom-10 opacity-10 text-9xl">
                    <i class="fas fa-chart-bar"></i>
                </div>
            </div>
        </div>

        <!-- Yearly Projection Table -->
        <div class="bg-white rounded-2xl shadow-sm border overflow-hidden">
            <div class="p-6 border-b flex justify-between items-center">
                <h2 class="text-xl font-bold">Kế hoạch tài chính 5 năm (VND)</h2>
                <span class="text-xs bg-blue-50 text-blue-600 px-3 py-1 rounded-full font-bold">Dự báo tăng trưởng</span>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-sm text-center">
                    <thead class="bg-slate-50 text-slate-500 font-bold uppercase text-xs">
                        <tr>
                            <th class="px-6 py-4 text-left">Chỉ số tài chính</th>
                            <th class="px-6 py-4">Năm 1</th>
                            <th class="px-6 py-4">Năm 2</th>
                            <th class="px-6 py-4">Năm 3</th>
                            <th class="px-6 py-4">Năm 4</th>
                            <th class="px-6 py-4">Năm 5</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y">
                        <tr class="bg-blue-50/30">
                            <td class="px-6 py-4 text-left font-bold text-slate-700">CASH EBITDA</td>
                            <td class="px-6 py-4 font-bold">1,367,247,636</td>
                            <td class="px-6 py-4">969,415,283</td>
                            <td class="px-6 py-4">935,424,420</td>
                            <td class="px-6 py-4">935,424,420</td>
                            <td class="px-6 py-4">935,424,420</td>
                        </tr>
                        <tr>
                            <td class="px-6 py-4 text-left font-medium text-slate-500 italic">Biên EBITDA (%)</td>
                            <td class="px-6 py-4">49.0%</td>
                            <td class="px-6 py-4">46.1%</td>
                            <td class="px-6 py-4">46.0%</td>
                            <td class="px-6 py-4">46.0%</td>
                            <td class="px-6 py-4">46.0%</td>
                        </tr>
                        <tr>
                            <td class="px-6 py-4 text-left font-medium text-slate-700">Free Cashflow</td>
                            <td class="px-6 py-4 font-semibold text-green-600">355,747,636</td>
                            <td class="px-6 py-4">969,415,283</td>
                            <td class="px-6 py-4">935,424,420</td>
                            <td class="px-6 py-4">935,424,420</td>
                            <td class="px-6 py-4">935,424,420</td>
                        </tr>
                        <tr class="text-xs text-slate-400">
                            <td class="px-6 py-4 text-left italic">Capex Investment</td>
                            <td class="px-6 py-4">879,000,000</td>
                            <td class="px-6 py-4">-</td>
                            <td class="px-6 py-4">-</td>
                            <td class="px-6 py-4">-</td>
                            <td class="px-6 py-4">-</td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <div class="p-4 bg-slate-50 text-xs text-slate-500 italic">
                * EBITDA / Total Capital Commitment đạt 155.5% trong năm đầu tiên.
            </div>
        </div>
    </main>

    <!-- Footer -->
    <footer class="bg-slate-900 text-slate-400 py-12 px-6 mt-12 border-t border-slate-800">
        <div class="max-w-6xl mx-auto flex flex-col md:flex-row justify-between items-center text-sm">
            <div class="mb-4 md:mb-0">
                <p class="font-bold text-white mb-1">Dự án Vật lý trị liệu Cali 2024</p>
                <p>Nền tảng phục hồi & chăm sóc sức khỏe chủ động.</p>
            </div>
            <div class="flex gap-6">
                <span>Update: 14/03</span>
                <span>Version: 2.0.1</span>
                <span>Author: Project Team</span>
            </div>
        </div>
    </footer>

    <script>
        function switchTab(tab) {
            const servicesTab = document.getElementById('tab-services');
            const businessTab = document.getElementById('tab-business');
            const btnServices = document.getElementById('btn-services');
            const btnBusiness = document.getElementById('btn-business');

            if (tab === 'services') {
                servicesTab.classList.remove('hidden');
                businessTab.classList.add('hidden');
                btnServices.classList.add('tab-active');
                btnServices.classList.remove('text-slate-500');
                btnBusiness.classList.remove('tab-active');
                btnBusiness.classList.add('text-slate-500');
            } else {
                servicesTab.classList.add('hidden');
                businessTab.classList.remove('hidden');
                btnBusiness.classList.add('tab-active');
                btnBusiness.classList.remove('text-slate-500');
                btnServices.classList.remove('tab-active');
                btnServices.classList.add('text-slate-500');
            }
        }
    </script>

</body>
</html>
